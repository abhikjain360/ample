{
    "name": "ample",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsgo && vite build",
        "preview": "vite preview",
        "tauri": "tauri",
        "build:prod": "bun run tauri build && ./src-tauri/bundle-mpv.sh src-tauri/target/release/bundle/macos/ample.app",
        "lint": "oxlint .",
        "tsgo": "tsgo --noEmit",
        "format": "prettier --write \"**/*.{json,ts,js,tsx,jsx,html,css}\" --ignore-path .gitignore",
        "format:check": "prettier --check \"**/*.{json,ts,js,tsx,jsx,html,css}\" --ignore-path .gitignore"
    },
    "dependencies": {
        "@radix-ui/react-slot": "^1.2.4",
        "@tailwindcss/vite": "^4.2.4",
        "@tauri-apps/api": "^2.10.1",
        "@tauri-apps/plugin-dialog": "^2.7.0",
        "@tauri-apps/plugin-log": "^2.8.0",
        "@tauri-apps/plugin-opener": "^2.5.3",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "fuse.js": "^7.3.0",
        "lucide-react": "^1.11.0",
        "next-themes": "^0.4.6",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-virtuoso": "^4.18.6",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.4",
        "wouter": "^3.9.0"
    },
    "devDependencies": {
        "@tauri-apps/cli": "^2.10.1",
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@typescript/native-preview": "^7.0.0-dev.20260425.1",
        "@vitejs/plugin-react": "^6.0.1",
        "oxlint": "^1.61.0",
        "prettier": "^3.8.3",
        "tw-animate-css": "^1.4.0",
        "typescript": "~6.0.3",
        "vite": "^8.0.10"
    }
}
